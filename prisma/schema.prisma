generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AccessControlSettings {
  id                  String   @id @default(uuid())
  key                 String   @unique @default("global")
  siteName            String   @default("Startap Admin")
  siteLogoFullLight   String?
  siteIcon            String?
  siteLogoFullDark    String?
  siteFavicon         String?
  loginPageLogo       String?
  themeMode           String   @default("system")
  primaryColor        String   @default("#2f8fe8")
  sidebarStyle        String   @default("default")
  layoutWidth         String   @default("boxed")
  headerStyle         String   @default("sticky")
  mailDriver          String   @default("smtp")
  fromName            String?
  fromEmail           String?
  smtpHost            String?
  smtpPort            Int?
  smtpUsername        String?
  smtpPassword        String?
  encryption          String   @default("tls")
  firebaseEnabled     Boolean  @default(false)
  firebaseProjectId   String?
  firebaseClientEmail String?
  firebasePrivateKey  String?
  firebaseServerKey   String?
  waafiEnabled        Boolean  @default(false)
  waafiEnvironment    String   @default("test")
  waafiApiBaseUrl     String?
  waafiMerchantUid    String?
  waafiApiUserId      String?
  waafiApiKey         String?
  waafiMerchantNumber String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AccessUser {
  id             String                @id @default(uuid())
  avatarUrl      String?
  firstName      String
  lastName       String
  username       String                @unique
  email          String                @unique
  passwordHash   String?
  displayName    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  roles          AccessUserRole[]
  activityLogs   AccessActivityLog[]   @relation("ActivityActor")
  passwordResets AccessPasswordReset[]
}

model AccessRole {
  id          String                 @id @default(uuid())
  name        String
  guardName   String                 @default("web")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  users       AccessUserRole[]
  permissions AccessRolePermission[]

  @@unique([name, guardName])
}

model AccessPermission {
  id        String                 @id @default(uuid())
  name      String
  guardName String                 @default("web")
  groupKey  String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  roles     AccessRolePermission[]

  @@unique([name, guardName])
}

model AccessUserRole {
  id        String     @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime   @default(now())
  user      AccessUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model AccessRolePermission {
  id           String           @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime         @default(now())
  role         AccessRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   AccessPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model AccessActivityLog {
  id          String      @id @default(uuid())
  type        String
  activity    String
  subject     String
  subjectId   String?
  userId      String?
  userDisplay String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  user        AccessUser? @relation("ActivityActor", fields: [userId], references: [id], onDelete: SetNull)
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberStatus {
  ACTIVE
  PENDING
  SUSPENDED
  EXPIRED
}

enum PlanType {
  MONTHLY
  QUARTERLY
  ANNUAL
  GROUP_TRAINING
  PERSONAL_TRAINING
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  PENDING
  SUSPENDED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  CASH
  MANUAL_EVC
  EVC_MANUAL
  BANK_TRANSFER
  OTHER_MANUAL_MOBILE_MONEY
  WAAFI_PAY
  WAAFI
  EVC_ONLINE
}

enum PaymentType {
  MANUAL
  ONLINE
}

enum OnlinePaymentProvider {
  EVC_PLUS
  JEEB
  ZAAD
  SAHAL
}

enum StoreProductStatus {
  PUBLISHED
  UNPUBLISHED
}

enum StoreBuyerType {
  MEMBER
  TRAINER
}

enum StoreOrderStatus {
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

enum AttendanceMethod {
  MANUAL
}

enum AttendanceStatus {
  PRESENT
  CANCELLED
}

enum NotificationType {
  PAYMENT_REMINDER
  SUBSCRIPTION_EXPIRY
  GYM_ANNOUNCEMENT
  UPGRADE_CONFIRMATION
  GENERAL_MESSAGE
  WORKOUT_ASSIGNED
  SCHEDULE_ASSIGNED
}

enum NotificationTarget {
  ALL_MEMBERS
  ALL_TRAINERS
  SINGLE_MEMBER
}

enum NotificationReadStatus {
  UNREAD
  READ
}

enum TrainerStatus {
  ACTIVE
  INACTIVE
}

enum WorkoutDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutStatus {
  ACTIVE
  INACTIVE
}

enum TrainerScheduleStatus {
  UPCOMING
  COMPLETED
  MISSED
  CANCELLED
}

enum MobileAccountRole {
  MEMBER
  TRAINER
}

enum MobileAccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MobileDevicePlatform {
  ANDROID
  IOS
  WEB
  UNKNOWN
}

model MobileAccount {
  id                         String                @id @default(uuid())
  role                       MobileAccountRole
  loginEmail                 String?
  loginPhone                 String?
  passwordHash               String
  temporaryPasswordEncrypted String?
  mustChangePassword         Boolean               @default(true)
  passwordChangedAt          DateTime?
  lastLoginAt                DateTime?
  accountStatus              MobileAccountStatus   @default(ACTIVE)
  welcomeEmailSentAt         DateTime?
  welcomeEmailError          String?
  memberId                   String?               @unique
  trainerId                  String?               @unique
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  member                     Member?               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer                    Trainer?              @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  passwordResets             MobilePasswordReset[]
  deviceTokens               MobileDeviceToken[]

  @@index([role])
  @@index([loginEmail])
  @@index([loginPhone])
  @@index([accountStatus])
}

model MobileDeviceToken {
  id         String               @id @default(uuid())
  accountId  String
  role       MobileAccountRole
  token      String               @unique
  platform   MobileDevicePlatform @default(UNKNOWN)
  deviceName String?
  topic      String?
  lastSeenAt DateTime             @default(now())
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  account    MobileAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([role])
  @@index([platform])
  @@index([lastSeenAt])
}

model AccessPasswordReset {
  id        String     @id @default(uuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  user      AccessUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MobilePasswordReset {
  id        String        @id @default(uuid())
  accountId String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  account   MobileAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model Member {
  id                String               @id @default(uuid())
  fullName          String
  phoneNumber       String
  email             String?              @unique
  gender            Gender
  address           String?
  dateOfBirth       DateTime?
  emergencyContact  String?
  profileImage      String?
  status            MemberStatus         @default(PENDING)
  trainerId         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  trainer           Trainer?             @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  subscriptions     Subscription[]
  payments          Payment[]
  attendance        Attendance[]
  notifications     Notification[]
  mobileAccount     MobileAccount?
  groupMemberships  TrainerGroupMember[]
  workouts          Workout[]
  trainerSchedules  TrainerSchedule[]
  storeOrders       StoreOrder[]
  storeTransactions StoreTransaction[]

  @@index([fullName])
  @@index([phoneNumber])
  @@index([status])
  @@index([trainerId])
}

model Trainer {
  id                String             @id @default(uuid())
  fullName          String
  phoneNumber       String
  email             String?            @unique
  gender            Gender
  specialty         String
  availability      String?
  profileImage      String?
  status            TrainerStatus      @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  members           Member[]
  mobileAccount     MobileAccount?
  groups            TrainerGroup[]
  workouts          Workout[]
  schedules         TrainerSchedule[]
  storeOrders       StoreOrder[]
  storeTransactions StoreTransaction[]

  @@index([fullName])
  @@index([status])
}

model TrainerGroup {
  id           String               @id @default(uuid())
  name         String
  trainingDays String?
  trainingTime String?
  status       TrainerStatus        @default(ACTIVE)
  trainerId    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  trainer      Trainer?             @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  members      TrainerGroupMember[]
  workouts     Workout[]
  schedules    TrainerSchedule[]

  @@index([trainerId])
  @@index([status])
}

model TrainerGroupMember {
  id        String       @id @default(uuid())
  groupId   String
  memberId  String
  createdAt DateTime     @default(now())
  group     TrainerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member    Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([groupId, memberId])
  @@index([memberId])
}

model Workout {
  id              String            @id @default(uuid())
  trainerId       String
  memberId        String?
  groupId         String?
  title           String
  description     String?
  image           String?
  sets            Int?
  reps            Int?
  durationMinutes Int?
  difficulty      WorkoutDifficulty @default(BEGINNER)
  category        String?
  status          WorkoutStatus     @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  trainer         Trainer           @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  member          Member?           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  group           TrainerGroup?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  schedules       TrainerSchedule[]

  @@index([trainerId])
  @@index([memberId])
  @@index([groupId])
  @@index([status])
}

model TrainerSchedule {
  id        String                @id @default(uuid())
  trainerId String
  memberId  String?
  groupId   String?
  workoutId String
  date      DateTime
  startTime String
  endTime   String
  notes     String?
  status    TrainerScheduleStatus @default(UPCOMING)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  trainer   Trainer               @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  member    Member?               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  group     TrainerGroup?         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  workout   Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([memberId])
  @@index([groupId])
  @@index([workoutId])
  @@index([date])
  @@index([status])
}

model MembershipPlan {
  id            String         @id @default(uuid())
  name          String
  type          PlanType
  durationDays  Int
  price         Decimal        @db.Decimal(10, 2)
  description   String?
  status        PlanStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  payments      Payment[]

  @@index([name])
  @@index([type])
  @@index([status])
}

model Subscription {
  id            String             @id @default(uuid())
  memberId      String
  planId        String
  startDate     DateTime
  expiryDate    DateTime
  status        SubscriptionStatus @default(PENDING)
  paymentStatus PaymentStatus      @default(PENDING)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  member        Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan          MembershipPlan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments      Payment[]

  @@index([memberId])
  @@index([planId])
  @@index([status])
  @@index([paymentStatus])
  @@index([expiryDate])
}

model Payment {
  id             String                 @id @default(uuid())
  memberId       String
  subscriptionId String?
  planId         String?
  amount         Decimal                @db.Decimal(10, 2)
  currency       String                 @default("USD")
  paymentType    PaymentType            @default(MANUAL)
  method         PaymentMethod
  onlineProvider OnlinePaymentProvider?
  status         PaymentStatus          @default(PENDING)
  paymentDate    DateTime               @default(now())
  paidAt         DateTime?
  reference      String?
  referenceId    String?
  invoiceId      String?
  requestId      String?
  notes          String?
  transactionId  String?
  phoneNumber    String?
  provider       String?
  failedReason   String?
  rawResponse    Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  member         Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)
  subscription   Subscription?          @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan           MembershipPlan?        @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([subscriptionId])
  @@index([planId])
  @@index([status])
  @@index([method])
  @@index([paymentType])
  @@index([onlineProvider])
  @@index([requestId])
  @@index([paymentDate])
}

model StoreProduct {
  id                String             @id @default(uuid())
  name              String
  category          String?
  image             String?
  description       String?
  price             Decimal            @db.Decimal(10, 2)
  availableQuantity Int                @default(0)
  status            StoreProductStatus @default(UNPUBLISHED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  orders            StoreOrder[]
  transactions      StoreTransaction[]

  @@index([name])
  @@index([category])
  @@index([status])
  @@index([availableQuantity])
}

model StoreOrder {
  id                      String                 @id @default(uuid())
  orderNumber             String                 @unique
  buyerName               String
  buyerType               StoreBuyerType
  buyerPhoneNumber        String
  memberId                String?
  trainerId               String?
  productId               String
  quantity                Int
  unitPrice               Decimal                @db.Decimal(10, 2)
  totalAmount             Decimal                @db.Decimal(10, 2)
  currency                String                 @default("USD")
  paymentMethod           PaymentMethod          @default(WAAFI_PAY)
  onlineProvider          OnlinePaymentProvider?
  evcTransactionReference String?
  paymentStatus           PaymentStatus          @default(PAID)
  orderStatus             StoreOrderStatus       @default(PROCESSING)
  requestId               String?
  referenceId             String?
  invoiceId               String?
  paidAt                  DateTime?
  orderDate               DateTime               @default(now())
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  member                  Member?                @relation(fields: [memberId], references: [id], onDelete: SetNull)
  trainer                 Trainer?               @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  product                 StoreProduct           @relation(fields: [productId], references: [id], onDelete: Restrict)
  transaction             StoreTransaction?

  @@index([buyerType])
  @@index([memberId])
  @@index([trainerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([orderDate])
}

model StoreTransaction {
  id                   String                 @id @default(uuid())
  transactionReference String?
  orderId              String?                @unique
  orderNumber          String?
  buyerName            String
  buyerType            StoreBuyerType
  phoneNumber          String
  memberId             String?
  trainerId            String?
  productId            String
  quantity             Int
  amount               Decimal                @db.Decimal(10, 2)
  currency             String                 @default("USD")
  paymentMethod        PaymentMethod          @default(WAAFI_PAY)
  provider             OnlinePaymentProvider?
  paymentStatus        PaymentStatus          @default(PENDING)
  requestId            String                 @unique
  referenceId          String?
  invoiceId            String?
  failedReason         String?
  rawResponse          Json?
  transactionDate      DateTime               @default(now())
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  order                StoreOrder?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  member               Member?                @relation(fields: [memberId], references: [id], onDelete: SetNull)
  trainer              Trainer?               @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  product              StoreProduct           @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transactionReference])
  @@index([orderNumber])
  @@index([buyerType])
  @@index([memberId])
  @@index([trainerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([transactionDate])
}

model Attendance {
  id          String           @id @default(uuid())
  memberId    String
  checkInDate DateTime         @default(now())
  method      AttendanceMethod @default(MANUAL)
  status      AttendanceStatus @default(PRESENT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  member      Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([checkInDate])
  @@index([status])
}

model Notification {
  id         String                 @id @default(uuid())
  title      String
  message    String
  type       NotificationType
  target     NotificationTarget     @default(ALL_MEMBERS)
  memberId   String?
  readStatus NotificationReadStatus @default(UNREAD)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  member     Member?                @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([target])
  @@index([memberId])
  @@index([readStatus])
  @@index([createdAt])
}
